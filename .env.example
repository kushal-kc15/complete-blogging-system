# InkSpire production environment configuration.
# Copy to .env for local production-style checks; never commit .env.
# Process-manager environment variables take precedence over this file.

# Required by blog_main.settings_prod. Generate with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Set DJANGO_DEBUG=False in any environment reachable from the internet
# (blog_main.settings defaults to True; blog_main.settings_prod always False).
DJANGO_DEBUG=False

# Comma-separated hosts and fully qualified CSRF origins.
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# blog_main.settings (env-var driven, SQLite-friendly) is used for the first
# Azure App Service deployment. Switch to blog_main.settings_prod once
# PostgreSQL/Redis/SMTP are provisioned.
DJANGO_SETTINGS_MODULE=blog_main.settings

# Optional: only needed once you migrate off SQLite, e.g.
# postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Production PostgreSQL configuration. These values are required by
# blog_main.settings_prod; use provider-managed credentials in production.
POSTGRES_DB=inkspire
POSTGRES_USER=inkspire_user
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_SSLMODE=require

# Production Redis configuration. Replace the local example with the real Redis URL.
REDIS_URL=redis://localhost:6379/1
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=inkspire

# Production SMTP configuration. Replace example hosts and addresses; never commit credentials.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=no-reply@example.com
SERVER_EMAIL=errors@example.com
EMAIL_SUBJECT_PREFIX=[InkSpire]

# Google OAuth login (django-allauth)
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add Authorized JavaScript Origins:
#      http://127.0.0.1:8000 (local)
#      https://inkspire.onrender.com (production)
# 4. Add Authorized Redirect URIs:
#      http://127.0.0.1:8000/accounts/google/login/callback/ (local)
#      https://inkspire.onrender.com/accounts/google/login/callback/ (production)
# 5. Copy Client ID and Client Secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# PYTHONANYWHERE SPECIFIC
# ===========================================
# On PythonAnywhere, set these in the WSGI configuration file
# or use a .env file in your project directory

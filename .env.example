# InkSpire - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# REQUIRED SETTINGS
# ===========================================

# Generate a new secret key with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-here-generate-a-new-one

# Set to False in production
DEBUG=False

# Your domain(s) - comma separated
# For PythonAnywhere: yourusername.pythonanywhere.com
# For custom domain: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=yourusername.pythonanywhere.com

# ===========================================
# OPTIONAL SETTINGS
# ===========================================

# Database (SQLite is default, no config needed)
# For PostgreSQL (recommended for larger sites):
# DATABASE_URL=postgres://user:password@localhost:5432/blogdb

# Google OAuth login
# Create OAuth credentials in Google Cloud Console and add:
# http://127.0.0.1:8000/accounts/google/login/callback/
# https://yourdomain.com/accounts/google/login/callback/
# as authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# PYTHONANYWHERE SPECIFIC
# ===========================================
# On PythonAnywhere, set these in the WSGI configuration file
# or use a .env file in your project directory
